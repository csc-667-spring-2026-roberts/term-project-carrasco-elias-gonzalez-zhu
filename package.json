{
  "name": "term-project",
  "version": "1.0.0",
  "description": "CSC 667 Term Project - Spring 2026",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,js}\" \"views/**/*.ejs\" \"docs/**/*.md\" \"**/*.{json,yaml,yml}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js}\" \"views/**/*.ejs\" \"docs/**/*.md\" \"**/*.{json,yaml,yml}\"",
    "clean": "rm -rf dist/",
    "migrate:create": "node-pg-migrate create -j ts",
    "migrate:up": "node-pg-migrate up -j ts --tsconfig tsconfig.migrations.json",
    "migrate:down": "node-pg-migrate down -j ts --tsconfig tsconfig.migrations.json",
    "check:db": "tsx src/scripts/db/check-database.ts",
    "check:auth": "tsx src/scripts/auth/check-auth.ts",
    "check:base:pr": "npm ci && npm run lint && npm run format:check && npm run build",
    "check:auth:local": "npm run db:schema && npm run check:auth",
    "check:auth:pr": "npm run lint && npm run format:check && npm run build && npm run db:schema && npm run check:auth",
    "check:data:pr": "npm run lint && npm run format:check && npm run build && npm run migrate:up && npm run check:db",
    "check:ui:pr": "npm run lint && npm run format:check && npm run build",
    "db:recreate": "tsx src/scripts/db/recreate-database.ts",
    "db:schema": "tsx src/scripts/db/setup-schema.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/ejs": "^3.1.5",
    "@types/express": "^4.17.25",
    "@types/express-session": "^1.18.2",
    "@types/node": "^20.11.0",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "node-pg-migrate": "^8.0.3",
    "prettier": "^3.2.0",
    "prettier-plugin-ejs": "^1.0.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^17.3.1",
    "ejs": "^3.1.10",
    "express": "^5.2.1",
    "express-session": "^1.18.2",
    "pg": "^8.20.0",
    "pg-promise": "^12.6.2"
  }
}

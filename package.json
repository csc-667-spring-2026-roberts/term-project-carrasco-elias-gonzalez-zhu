{
  "name": "term-project",
  "version": "1.0.0",
  "description": "CSC 667 Term Project - Spring 2026",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "setup": "npm ci",
    "setup:clean": "rm -rf node_modules && npm ci",
    "build": "tsc && npm run build:client",
    "build:client": "esbuild src/client/lobby.ts --bundle --outdir=public/js --sourcemap",
    "start": "node dist/server.js",
    "dev": "concurrently -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch src/server.ts",
    "dev:client": "esbuild src/client/lobby.ts --bundle --outdir=public/js --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,js}\" \"views/**/*.ejs\" \"docs/**/*.{md,ts,sql}\" \"**/*.{json,yaml,yml}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js}\" \"views/**/*.ejs\" \"docs/**/*.{md,ts,sql}\" \"**/*.{json,yaml,yml}\"",
    "clean": "rm -rf dist/",
    "migrate:create": "node-pg-migrate create -j ts",
    "migrate:up": "node-pg-migrate up -j ts --tsconfig tsconfig.migrations.json",
    "migrate:down": "node-pg-migrate down -j ts --tsconfig tsconfig.migrations.json",
    "check:base:pr": "npm run lint && npm run format:check && npm run build",
    "db:recreate": "tsx src/scripts/db/recreate-database.ts",
    "db:clear": "dotenv -e .env -- sh -c 'psql \"$DATABASE_URL\" -c \"TRUNCATE session, users, games, game_users RESTART IDENTITY CASCADE;\"'",
    "db:check:empty": "dotenv -e .env -- sh -c 'psql \"$DATABASE_URL\" -c \"SELECT COUNT(*) AS users_count FROM users; SELECT COUNT(*) AS session_count FROM session; SELECT COUNT(*) AS games_count FROM games; SELECT COUNT(*) AS game_users_count FROM game_users;\"'",
    "db:clear:check": "npm run db:clear && npm run db:check:empty",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/ejs": "^3.1.5",
    "@types/express": "^4.17.25",
    "@types/express-session": "^1.18.2",
    "@types/node": "^20.11.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "node-pg-migrate": "^8.0.3",
    "prettier": "^3.2.0",
    "prettier-plugin-ejs": "^1.0.3",
    "prettier-plugin-sql": "^0.20.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "concurrently": "^9.2.1",
    "connect-livereload": "^0.6.1",
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^17.3.1",
    "ejs": "^3.1.10",
    "esbuild": "^0.27.5",
    "express": "^5.2.1",
    "express-session": "^1.18.2",
    "livereload": "^0.10.3",
    "pg": "^8.20.0",
    "pg-promise": "^12.6.2"
  }
}

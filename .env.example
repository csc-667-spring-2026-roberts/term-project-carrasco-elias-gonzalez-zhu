# Application port (default is 3000)
PORT=3000

# DATABASE_URL

# Mac (default)
DATABASE_URL=postgres://localhost:5432/term_project_dev

# Windows (see docs/m5/m5-postgresql-installation.md for configuration)
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/term_project_dev

# Secret used for sessions (update in M6: Authentication)
SESSION_SECRET=change-me
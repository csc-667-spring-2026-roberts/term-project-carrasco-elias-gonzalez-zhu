# App
# Port the server will run on
PORT=3000

# Database
# Mac (default)
# Uses your local PostgreSQL installation and default user
DATABASE_URL=postgres://localhost:5432/term_project_dev

# Windows
# Replace YOUR_PASSWORD with your PostgreSQL password
# Only update this line in your local `.env`, NOT in `.env.example`
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/term_project_dev

# Session
# Secret used to sign session cookies
# For local development, you may temporarily use: dev-secret
# For better security, generate a strong random value with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me
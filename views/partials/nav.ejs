<%#
  TODO Breanna:
  You may update styling (classes, layout, structure) in this file.

  Constraints:
  - Do NOT change logout form action: /auth/logout
  - Do NOT change logout form method: POST
  - Do NOT change login/register link paths
  - Do NOT remove usage of "user" or "error"

  This file controls shared navigation and session-based UI.
  %>

<nav class="site-nav">
  <div class="nav-inner">
    <a href="/" class="nav-brand">Hearts Lobby</a>

    <div class="nav-links">
      <a href="/" class="nav-link">Home</a>

      <% if (user) { %>
      <span class="nav-user"> Welcome, <%= user.display_name || "Player" %> </span>

      <form action="/auth/logout" method="POST" class="nav-form">
        <button type="submit" class="btn btn-secondary btn-small">Logout</button>
      </form>
      <% } else { %>
      <a href="/auth/login" class="nav-link">Login</a>
      <a href="/auth/register" class="nav-link">Register</a>
      <% } %>
    </div>
  </div>
</nav>

<% if (error) { %>
<div class="alert alert-error"><%= error %></div>
<% } %>

  Constraints:
  - Do NOT change form action: /auth/login
  - Do NOT change form method: POST
  - Do NOT change input names: email, password
  - Do NOT change redirect flow

  This file must remain compatible with the auth route contract.
  %>

<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include("../partials/head") %>
  </head>
  <body class="app-shell">
    <%- include("../partials/nav") %>

    <main class="page-wrap auth-page">
      <section class="auth-card">
        <div class="auth-header">
          <h1>Login</h1>
          <p class="auth-subtitle">Sign in to continue to the lobby.</p>
        </div>

        <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
        <% } %>

        <form action="/auth/login" method="POST" class="auth-form">
          <div class="form-group">
            <label for="email" class="form-label">Email</label>
            <input id="email" type="email" name="email" class="form-input" required />
          </div>

          <div class="form-group">
            <label for="password" class="form-label">Password</label>
            <input id="password" type="password" name="password" class="form-input" required />
          </div>

          <div class="form-actions">
            <button type="submit" class="btn btn-primary">Login</button>
          </div>
        </form>

        <p class="auth-helper">
          Don’t have an account?
          <a href="/auth/register">Register</a>
        </p>
      </section>
    </main>
  </body>
</html>
